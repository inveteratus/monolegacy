{% extends 'layouts/app.twig' %}

{% block content %}

    <h2 class="text-3xl font-light border-b border-slate-200 mb-3">Travel Agent</h2>

    <form method="post" class="grid grid-cols-4 gap-3">
        {% for id, city in cities %}
            {% if user.city_id == id %}
                <div class="border border-slate-300 bg-slate-50 flex flex-col items-center justify-center py-3 rounded shadow">
                    <span class="font-medium text-slate-500">{{ city.name }}</span>
                    <span class="text-sm text-slate-500">Current location</span>
                </div>
            {% else %}
                <button type="submit" name="destination" value="{{ id }}" class="border border-slate-300 bg-slate-50 flex flex-col items-center justify-center py-3 rounded shadow hover:bg-blue-100">
                    <span class="font-medium">{{ city.name }}</span>
                    <span class="text-sm">{{ number_format(city.cost) }} Cr</span>
                </button>
            {% endif %}
        {% endfor %}
    </form>

{% endblock %}
