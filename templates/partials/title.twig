
<h2 class="border-b border-slate-200 flex justify-between items-end">
    <span class="text-3xl font-light">{{ title }}</span>
    {% if links %}
        <div>
            {% for label, href in links %}
                <a href="{{ href }}" class="text-blue-500">{{ label }}</a>
                {% if not loop.last %}
                    <span>&raquo;</span>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
</h2>
