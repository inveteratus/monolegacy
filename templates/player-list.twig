{% extends 'layouts/app.twig' %}

{% block content %}

    <h2 class="text-3xl font-light border-b border-slate-200 mb-3">Player List</h2>

    <table class="w-full shadow rounded overflow-hidden">
        <thead class="bg-slate-200">
            <tr>
                <th class="font-medium text-left p-2">Name</th>
                <th class="font-medium text-left p-2">Location</th>
                <th class="font-medium text-left p-2">Last Seen</th>
            </tr>
        </thead>
        <tbody class="bg-slate-50">
            {% for player in players %}
                <tr class="border-t border-slate-200 hover:bg-blue-100">
                    <td class="text-left p-2">{{ player.name }}</td>
                    <td class="text-left p-2">{{ player.location }}</td>
                    <td class="text-left p-2">{{ player.last_seen|delta }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

{% endblock %}
