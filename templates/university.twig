{% extends 'layouts/app.twig' %}

{% block content %}

    <h2 class="text-3xl font-light border-b border-slate-200 mb-3">City University</h2>

    {% if user.course_id %}
        <p>You are currently studying &ldquo;<span class="font-medium">{{ courses.items[user.course_id].name }}</span>&rdquo;. It will be complete in approximately {{ user.course_completed|delta }}.</p>
    {% else %}
        <div class="grid grid-cols-2 gap-3">
            {% for id, course in courses.items %}
                <a href="/university/{{ course.slug }}" class="border border-slate-200 bg-slate-50 flex flex-col items-center justify-between p-3">
                    <span class="font-medium">{{ course.name }}</span>
                    <span class="text-sm">{{ number_format(course.cost) }} Cr</span>
                </a>
            {% endfor %}
        </div>
        {% if courses.pages > 1 %}
            {% include 'partials/pagination.twig' with {'page': courses.page, 'pages': courses.pages} %}
        {% endif %}
    {% endif %}

{% endblock %}
